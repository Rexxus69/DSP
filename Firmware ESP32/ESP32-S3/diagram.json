{
  "version": 1,
  "author": "DSP Controller",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-s3-devkitc-1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": { "psramSize": "8", "flashSize": "16" }
    },
    {
      "type": "wokwi-pcf8574",
      "id": "pcf",
      "top": 180,
      "left": 320,
      "attrs": { "address": "0x20" }
    },
    {
      "type": "wokwi-rotary-encoder",
      "id": "enc",
      "top": 180,
      "left": 520,
      "attrs": {}
    }
  ],
  "connections": [
    [ "esp:GPIO15", "pcf:SDA", "blue",   [] ],
    [ "esp:GPIO7",  "pcf:SCL", "yellow", [] ],
    [ "esp:GND.1",  "pcf:GND", "black",  [] ],
    [ "esp:3V3",    "pcf:VCC", "red",    [] ],

    [ "pcf:P0", "enc:CLK", "green",  [] ],
    [ "pcf:P1", "enc:DT",  "white",  [] ],
    [ "pcf:P2", "enc:SW",  "purple", [] ],
    [ "enc:GND", "esp:GND.2", "black", [] ],

    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ]
  ]
}
